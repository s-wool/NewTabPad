{
  "manifest_version": 3,
  "name": "NewTabPad",
  "version": "0.1.0",
  "description": "新しいタブをシンプルなプレーンテキストのメモ帳に置き換えます。",
  "permissions": ["storage", "unlimitedStorage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
